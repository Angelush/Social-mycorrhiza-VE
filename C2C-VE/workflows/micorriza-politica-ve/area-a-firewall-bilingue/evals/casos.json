    {"key": "rango_de_fechas", "expect": "admit", "note": "AC-T4 ('ban' no aparece como token)"},
    {"key": "puntuacion", "expect": "reject", "note": "AC-T2, sin tilde"},
    {"key": "puntuación", "expect": "reject", "note": "AC-T2, con tilde (NFD)"},
    {"key": "cedula", "expect": "reject", "note": "AC-T2"},
    {"key": "cédula", "expect": "reject", "note": "AC-T2, con tilde"},
    {"key": "rif", "expect": "reject", "note": "AC-T2"},
    {"key": "lista_negra", "expect": "reject", "note": "AC-Ta5, bigrama"},
    {"key": "listaNegra", "expect": "reject", "note": "AC-Ta5, bigrama camelCase"},
    {"key": "lista", "expect": "admit", "note": "AC-Ta5, token individual no prohibido"},
    {"key": "negra", "expect": "admit", "note": "AC-Ta5, token individual no prohibido"},
    {"key": "score", "expect": "reject", "note": "taxonomia base"},
    {"key": "reputacion", "expect": "reject", "note": "variante castellana"},
    {"key": "global_id", "expect": "reject", "note": "compuesto de dos tokens, taxonomia completa"},
